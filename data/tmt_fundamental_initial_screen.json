{
  "schema_version": "1.0",
  "created_for": "alpha_gen TMT fundamental factor pre-screen",
  "created_date": "2026-05-08",
  "source": "User-provided screenshots of rqf_growth, rqf_income, rqf_balancesheet, rqf_cashflow, rqf_der_financial, rqf_der_cashflow, rqf_der_operating and rqf_der_valuation columns.",
  "universe": "TMT A-share industry universe",
  "principles": [
    "This file is an economic-meaning pre-screen only. It does not replace later statistical quality checks such as coverage, stale values, outliers, cross-sectional dispersion and redundancy.",
    "Fields in whitelist_core should be protected from purely mechanical coverage filtering when their TMT relevance is high, especially R&D, growth, margin, cash-flow and valuation fields.",
    "Fields in keep_candidate are economically usable for TMT but should pass normal quality thresholds before entering the GA search pool.",
    "Fields in review_quality_or_definition are not deleted by economic logic, but require closer checks for coverage, disclosure stability, accounting noise, sign convention or duplicated definition.",
    "Fields in drop_financial_or_insurance_specific should not enter the TMT main pool because their accounting meaning belongs mainly to banks, brokers, insurers or other financial institutions.",
    "Fields in drop_noise_or_low_signal are not preferred for the TMT main GA pool because they are one-off, OCI, low interpretability, pure accounting reserve items, or weaker duplicates of better derived metrics."
  ],
  "role_policy": [
    {
      "role": "y",
      "meaning": "Can appear on the signal side of a GA expression.",
      "default_for_decisions": [
        "whitelist_core",
        "keep_candidate"
      ]
    },
    {
      "role": "x",
      "meaning": "Can appear as denominator, control variable, or residualization side.",
      "default_for_decisions": [
        "whitelist_control_x",
        "keep_candidate"
      ]
    },
    {
      "role": "review",
      "meaning": "Do not automatically enter GA; inspect quality report first.",
      "default_for_decisions": [
        "review_quality_or_definition"
      ]
    },
    {
      "role": "drop",
      "meaning": "Remove from TMT main pool before build_transform_cache.",
      "default_for_decisions": [
        "drop_financial_or_insurance_specific",
        "drop_noise_or_low_signal"
      ]
    }
  ],
